# BackOffice Apache Configuration
RewriteEngine On

# Autoriser l'accès direct aux fichiers statiques (images, css, js)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^.*$ - [L]

# Autoriser l'accès direct aux dossiers existants
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^.*$ - [L]

# API publique (pas d'authentification requise)
RewriteRule ^api/.*$ - [L]

# Uploads publics (pas d'authentification requise)
RewriteRule ^uploads/.*$ - [L]
